# casa de ervas jupira — exemplo de ambiente
# copie para .env localmente e preencha com suas credenciais reais.
# nunca commite .env com chaves reais.

GOOGLE_API_KEY=""
GOOGLE_VERTEX_AI_KEY=""
GOOGLE_OAUTH_CLIENT_ID=""

# opcional: projeto/região quando usar vertex ai
GOOGLE_CLOUD_PROJECT_ID=""
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_IMAGE_MODEL="imagen-4.0-generate-001"

# instagram / publicação
INSTAGRAM_PROFILE="@casadeervasjupira"
